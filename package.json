{
  "name": "personal-asistent",
  "version": "0.1.0",
  "description": "Agente de programación headless con ACP vía stdio JSON-RPC",
  "license": "MIT",
  "keywords": ["acp", "agent", "cli", "bun", "stdio", "json-rpc", "zed", "jetbrains", "programming-assistant"],
  "repository": {
    "type": "git",
    "url": "https://github.com/personal-asistent/personal-asistent.git"
  },
  "bugs": {
    "url": "https://github.com/personal-asistent/personal-asistent/issues"
  },
  "homepage": "https://github.com/personal-asistent/personal-asistent#readme",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "dist/index.js",
  "main": "dist/index.js",
  "bin": {
    "personal-asistent": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:prod": "NODE_ENV=production tsup",
    "dev": "bun --hot run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "start": "bun dist/index.js",
    "spike": "bun run scripts/spike-client.ts",
    "tui": "bun run scripts/tui-client.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "8.5.1",
    "@types/bun": "1.2.0",
    "@zed-industries/agent-client-protocol": "0.4.5",
    "@anthropic-ai/sdk": "0.91.1",
    "openai": "6.34.0",
    "toml": "4.1.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=20.0.0"
  }
}
